{
  "name": "lopbox",
  "version": "1.0.0",
  "description": "LopBox - game library manager on Electrobun",
  "author": "LopBox",
  "homepage": "https://electrobun.dev",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "gen:db": "kysely-codegen --dialect sqlite --url ./db/gameData.db --out-file src/main/types/database.d.ts",
    "build:web": "vite build",
    "dev": "bun run build:web && bunx electrobun dev",
    "dev:hmr": "concurrently -k -n vite,app -c cyan,magenta \"vite\" \"bunx electrobun dev\"",
    "start": "bun run dev",
    "build": "bun run build:web && bunx electrobun build",
    "typecheck": "tsc --noEmit -p tsconfig.web.json --composite false",
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build",
    "build:fonts": "node scripts/fontBuilder.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tanstack/react-query": "^5.90.5",
    "dayjs": "^1.11.18",
    "electrobun": "^1.18.1",
    "gsap": "^3.13.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-photo-view": "^1.2.7",
    "react-responsive-masonry": "^2.7.1",
    "react-router-dom": "^7.7.1",
    "recharts": "^3.1.2",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fontmin": "^1.1.1",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3",
    "vite": "^7.2.6"
  }
}
